---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Background from '../components/Background.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="404 | Dulal Denislam" description="お探しのページは見つかりませんでした。" noindex>
  <div class="mn-root">
    <Background effects={false} />
    <Header />

    <div class="mn-wrap">
      <main class="mn-main">
        <div class="mn-eyebrow"><span>404</span></div>
        <h1 class="mn-name md">Not found.</h1>
        <p class="mn-tagline static">
          お探しのページは見つかりませんでした。<br />
          <a href="/" class="mn-back-link">トップへ戻る →</a>
        </p>
      </main>
    </div>

    <Footer />
  </div>
</Layout>

<style is:global>
  .mn-back-link { color: var(--accent-bright); }
</style>
