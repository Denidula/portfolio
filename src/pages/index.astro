---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Background from '../components/Background.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

const fullName = 'Dulal Denislam.';
const chars = fullName.split('');
---

<Layout title="Dulal Denislam">
  <div class="mn-root">
    <Background />
    <Header active="about" drawer />

    <div class="mn-wrap has-rail">
      <!-- MAIN -->
      <main class="mn-main">
        <div class="mn-eyebrow"><span>PORTFOLIO</span></div>

        <!--
          1文字ずつのアニメ用spanはスクリーンリーダーだと
          「D, u, l, a, l…」と読まれてしまうため、
          h1 に aria-label / span側に aria-hidden を付与
        -->
        <h1 class="mn-name" aria-label={fullName}>
          <span aria-hidden="true">
            {chars.map((c, i) => (
              <span class="char" style={`animation-delay:${(0.2 + i * 0.09).toFixed(2)}s`}>
                {c === ' ' ? '\u00a0' : c}
              </span>
            ))}
          </span>
        </h1>
        <div class="mn-name-ja">デニスラム ドゥラル</div>

        <p class="mn-tagline">
          インフラチームを率いながら、<em>AI推進</em>に力を入れて活動しています。
        </p>

        <div class="mn-hero-foot">
          <div>
            <div class="mn-fact-k">ROLE</div>
            <div class="mn-fact-v">Project Leader</div>
          </div>
          <div>
            <div class="mn-fact-k">FOCUS</div>
            <div class="mn-fact-v">AI in production</div>
          </div>
          <div>
            <div class="mn-fact-k">TENURE</div>
            <div class="mn-fact-v">5 years +</div>
          </div>
          <div>
            <div class="mn-fact-k">STATUS</div>
            <div class="mn-fact-v">Open to projects</div>
          </div>
        </div>

        <About />
        <Contact />
      </main>

      <!-- RIGHT META RAIL -->
      <aside class="mn-meta-rail">
        <div class="mn-meta-block">
          <div class="mn-meta-h">— STATUS</div>
          <div class="mn-status"><span class="pulse"></span>Active · Open to projects</div>
        </div>

        <div class="mn-meta-block">
          <div class="mn-meta-h">— CURRENTLY</div>
          <div class="mn-meta-body" style="line-height:1.65;">
            社内AI導入プログラムの立ち上げ。運用保守監視チームのリードと並走しながら、必要な仕組みを後ろから組み上げているところ。
          </div>
        </div>

        <div class="mn-meta-block">
          <div class="mn-meta-h">— STACK</div>
          <div class="mn-meta-body">
            <div class="item"><span>TypeScript</span><span class="v">daily</span></div>
            <div class="item"><span>Python</span><span class="v">daily</span></div>
            <div class="item"><span>LLMs / RAG</span><span class="v">project</span></div>
            <div class="item"><span>Astro · React</span><span class="v">side</span></div>
            <div class="item"><span>Team design</span><span class="v">always</span></div>
          </div>
        </div>

        <div class="mn-meta-block">
          <div class="mn-meta-h">— LOCAL TIME</div>
          <div class="mn-clock"><b id="local-clock">--:--</b> JST · Shinjuku</div>
        </div>

        <div class="mn-meta-block">
          <div class="mn-meta-h">— UPCOMING</div>
          <div class="mn-meta-body sub">
            ・富士山登頂（夏）<br />
            ・登壇予定（社内AI事例）<br />
            ・Works ページを順次追加
          </div>
        </div>
      </aside>
    </div>

    <!-- FOOTER -->
    <Footer />
  </div>
</Layout>

<!-- メタレール専用CSS（このページにしか無いため Layout から移動） -->
<style is:global>
  .mn-meta-rail { padding-top: 24px; position: sticky; top: 40px; }
  .mn-meta-block { margin-bottom: 32px; }
  .mn-meta-h {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--text-faint);
    letter-spacing: 0.06em;
    margin-bottom: 12px;
  }
  .mn-meta-body { font-size: 12.5px; color: var(--text-soft); line-height: 1.7; }
  .mn-meta-body.sub { font-size: 12px; color: var(--text-muted); }
  .mn-meta-body .item {
    display: flex;
    justify-content: space-between;
    padding: 5px 0;
    border-top: 1px solid var(--hairline);
  }
  .mn-meta-body .item:first-child { border-top: none; }
  .mn-meta-body .item .v { font-family: var(--font-mono); font-size: 11px; color: var(--text-muted); }
  .mn-status { display: flex; align-items: center; gap: 8px; font-size: 12.5px; color: var(--text); }
  .mn-status .pulse { width: 8px; height: 8px; background: var(--text); border-radius: 50%; position: relative; }
  .mn-status .pulse::before {
    content: '';
    position: absolute;
    inset: -4px;
    border-radius: 50%;
    border: 1px solid var(--text);
    opacity: 0.3;
    animation: mn-pulse 2.2s ease-out infinite;
  }
  @keyframes mn-pulse {
    0% { transform: scale(0.6); opacity: 0.6; }
    100% { transform: scale(1.8); opacity: 0; }
  }
  .mn-clock { font-family: var(--font-mono); font-size: 11px; color: var(--text-faint); letter-spacing: 0.04em; }
  .mn-clock b { color: var(--text-dim); font-weight: 400; }

  @media (max-width: 1100px) {
    .mn-meta-rail { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .mn-status .pulse::before { animation: none; }
  }
</style>

<script>
  import '../scripts/effects';
  // ドロワー / ナビ同期 → Header.astro
  // フォーム送信        → Contact.astro
  // fade-up            → effects.ts
  // へそれぞれ移動済み。このページに残るのは時計だけ。

  // ===== Local clock (JST) =====
  // 分境界に合わせて setTimeout を張り直す（最大15秒の表示ズレを解消）
  const clockEl = document.getElementById('local-clock');
  if (clockEl) {
    const fmt = new Intl.DateTimeFormat('ja-JP', {
      timeZone: 'Asia/Tokyo',
      hour: '2-digit',
      minute: '2-digit',
      hour12: false,
    });
    const updateClock = () => {
      const now = new Date();
      clockEl.textContent = fmt.format(now);
      const msToNextMinute = 60000 - (now.getSeconds() * 1000 + now.getMilliseconds());
      setTimeout(updateClock, msToNextMinute + 50);
    };
    updateClock();
  }
</script>
