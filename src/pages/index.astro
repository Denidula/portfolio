---
import Layout from '../layouts/Layout.astro';
import About from '../components/About.astro';
import Contact from '../components/Contact.astro';

const fullName = 'Dulal Denislam.';
const chars = fullName.split('');
---

<Layout title="Dulal Denislam">
  <div class="mn-root">
    <canvas class="mn-trail-canvas" aria-hidden="true"></canvas>

    <div class="mn-bg grid-glow">
      <div class="glow-soft"></div>
      <div class="mn-star"></div>
    </div>

    <!-- TOP BAR -->
    <header class="mn-topbar">
      <button class="mn-brand-btn" id="brand-btn" aria-expanded="false" aria-controls="mn-drawer">
        <span class="dot"></span>
        <span class="name">Dulal Denislam</span>
        <span class="caret" aria-hidden="true">▾</span>
      </button>
      <nav class="mn-nav-top" id="nav-top">
        <a href="#mn-about" data-nav="about" class="active">About</a>
        <a href="/works" data-nav="works">Works</a>
        <a href="#mn-contact" data-nav="contact">Contact</a>
      </nav>
    </header>

    <!-- META DRAWER -->
    <div id="mn-drawer" class="mn-drawer" aria-hidden="true">
      <div class="mn-drawer-inner">
        <div class="mn-drawer-content">
          <div>PROJECT LEADER</div>
          <div>AI SPECIALIST</div>
          <div style="margin-top:6px;">Shinjuku, <b>JP</b></div>
          <div>Working since <b>2020</b></div>
        </div>
      </div>
    </div>

    <div class="mn-wrap">
      <!-- MAIN -->
      <main class="mn-main">
        <div class="mn-eyebrow"><span>PORTFOLIO</span></div>

        <h1 class="mn-name">
          {chars.map((c, i) => (
            <span class="char" style={`animation-delay:${(0.2 + i * 0.09).toFixed(2)}s`}>
              {c === ' ' ? '\u00a0' : c}
            </span>
          ))}
        </h1>
        <div class="mn-name-ja">デニスラム ドゥラル</div>

        <p class="mn-tagline">
          インフラチームを率いながら、<em>AI推進</em>に力を入れて活動しています。
        </p>

        <div class="mn-hero-foot">
          <div>
            <div class="mn-fact-k">ROLE</div>
            <div class="mn-fact-v">Project Leader</div>
          </div>
          <div>
            <div class="mn-fact-k">FOCUS</div>
            <div class="mn-fact-v">AI in production</div>
          </div>
          <div>
            <div class="mn-fact-k">TENURE</div>
            <div class="mn-fact-v">5 years +</div>
          </div>
          <div>
            <div class="mn-fact-k">STATUS</div>
            <div class="mn-fact-v">Open to projects</div>
          </div>
        </div>

        <About />
        <Contact />
      </main>

      <!-- RIGHT META RAIL -->
      <aside class="mn-meta-rail">
        <div class="mn-meta-block">
          <div class="mn-meta-h">— STATUS</div>
          <div class="mn-status"><span class="pulse"></span>Active · Open to projects</div>
        </div>

        <div class="mn-meta-block">
          <div class="mn-meta-h">— CURRENTLY</div>
          <div class="mn-meta-body" style="line-height:1.65;">
            社内AI導入プログラムの立ち上げ。運用保守監視チームのリードと並走しながら、必要な仕組みを後ろから組み上げているところ。
          </div>
        </div>

        <div class="mn-meta-block">
          <div class="mn-meta-h">— STACK</div>
          <div class="mn-meta-body">
            <div class="item"><span>TypeScript</span><span class="v">daily</span></div>
            <div class="item"><span>Python</span><span class="v">daily</span></div>
            <div class="item"><span>LLMs / RAG</span><span class="v">project</span></div>
            <div class="item"><span>Astro · React</span><span class="v">side</span></div>
            <div class="item"><span>Team design</span><span class="v">always</span></div>
          </div>
        </div>

        <div class="mn-meta-block">
          <div class="mn-meta-h">— LOCAL TIME</div>
          <div class="mn-clock"><b id="local-clock">--:--</b> JST · Shinjuku</div>
        </div>

        <div class="mn-meta-block">
          <div class="mn-meta-h">— UPCOMING</div>
          <div class="mn-meta-body" style="font-size:12px; color:#8a8884;">
            ・富士山登頂（夏）<br />
            ・登壇予定（社内AI事例）<br />
            ・Works ページを順次追加
          </div>
        </div>
      </aside>
    </div>

    <!-- FOOTER -->
    <footer class="mn-footer-bottom">
      <div class="mn-sns-row">
        <a class="mn-sns-link" href="https://github.com/Denidula" target="_blank" rel="noopener" aria-label="GitHub">
          <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38v-1.34c-2.22.48-2.69-1.07-2.69-1.07-.36-.92-.89-1.17-.89-1.17-.73-.5.05-.49.05-.49.81.06 1.23.83 1.23.83.72 1.23 1.88.87 2.34.67.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.01.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.03 2.2-.82 2.2-.82.44 1.11.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48v2.2c0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        </a>
        <a class="mn-sns-link" href="#" aria-label="X / Twitter">
          <svg viewBox="0 0 16 16" width="13" height="13" fill="currentColor" aria-hidden="true"><path d="M9.52 6.78L15.46 0h-1.4L8.9 5.88 4.78 0H0l6.23 8.9L0 16h1.41l5.45-6.21L11.22 16H16M1.92 1.04h2.16l9.93 13.96h-2.16"/></svg>
        </a>
        <a class="mn-sns-link" href="#" aria-label="LinkedIn">
          <svg viewBox="0 0 16 16" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M13.6 13.6h-2.37V9.9c0-.88-.02-2.02-1.23-2.02-1.23 0-1.42.96-1.42 1.96v3.76H6.2V6h2.27v1.04h.03c.32-.6 1.09-1.23 2.24-1.23 2.4 0 2.85 1.58 2.85 3.63v4.16zM3.55 4.96a1.37 1.37 0 110-2.74 1.37 1.37 0 010 2.74zm1.18 8.64H2.36V6h2.37v7.6zM14.78 0H1.22A1.21 1.21 0 000 1.18v13.64A1.21 1.21 0 001.22 16h13.56A1.21 1.21 0 0016 14.82V1.18A1.21 1.21 0 0014.78 0z"/></svg>
        </a>
      </div>
      <div class="mn-copyright">© 2026 <b>Dulal Denislam</b></div>
    </footer>
  </div>
</Layout>

<script>
  // ===== Meta drawer toggle =====
  const brand = document.getElementById('brand-btn');
  const drawer = document.getElementById('mn-drawer');
  if (brand && drawer) {
    brand.addEventListener('click', () => {
      const open = brand.classList.toggle('open');
      drawer.classList.toggle('open', open);
      brand.setAttribute('aria-expanded', String(open));
      drawer.setAttribute('aria-hidden', String(!open));
    });
  }

  // ===== D: Nav active sync =====
  const navLinks = Array.from(document.querySelectorAll<HTMLAnchorElement>('#nav-top a'));
  const setActive = (nav: string) => {
    navLinks.forEach((a) => a.classList.toggle('active', a.dataset.nav === nav));
  };
  const watched = ['mn-about', 'mn-hobbies', 'mn-contact']
    .map((id) => document.getElementById(id))
    .filter(Boolean) as HTMLElement[];
  if (watched.length) {
    const navObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) setActive((e.target as HTMLElement).dataset.nav || 'about');
        });
      },
      { threshold: 0.25, rootMargin: '-15% 0px -55% 0px' }
    );
    watched.forEach((s) => navObs.observe(s));
  }

  // ===== C: Fade-up on scroll =====
  const fadeEls = document.querySelectorAll('.fade-up');
  if (fadeEls.length) {
    const fadeObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('visible');
            fadeObs.unobserve(e.target);
          }
        });
      },
      { threshold: 0.12 }
    );
    fadeEls.forEach((el) => fadeObs.observe(el));
  }

  // ===== Star scroll guide =====
  const star = document.querySelector('.mn-star') as HTMLElement | null;
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (star && !reduce) {
    const getAnchors = () =>
      [
        document.querySelector('.mn-name'),
        ...Array.from(document.querySelectorAll('.mn-section-num')),
      ].filter(Boolean) as HTMLElement[];
    let anchors = getAnchors();
    const firstRect = anchors[0]?.getBoundingClientRect();
    let curY = firstRect ? firstRect.top + firstRect.height / 2 : window.innerHeight * 0.1;
    let t = 0;
    const tick = () => {
      t += 0.016;
      const vc = window.innerHeight * 0.42;
      let best = anchors[0];
      let bestDist = Infinity;
      for (const el of anchors) {
        const r = el.getBoundingClientRect();
        const c = r.top + r.height / 2;
        const d = Math.abs(c - vc);
        if (d < bestDist) { bestDist = d; best = el; }
      }
      if (best) {
        const r = best.getBoundingClientRect();
        curY += (r.top + r.height / 2 - curY) * 0.085;
      }
      const breath = 1 + Math.sin(t * 1.4) * 0.08;
      star.style.top = curY + 'px';
      star.style.setProperty('--breath', String(breath));
      requestAnimationFrame(tick);
    };
    tick();
    window.addEventListener('resize', () => { anchors = getAnchors(); });
  }

  // ===== E: Cursor trail (geometric) =====
  const canvas = document.querySelector('.mn-trail-canvas') as HTMLCanvasElement | null;
  if (canvas && !reduce) {
    const ctx = canvas.getContext('2d')!;
    let w = (canvas.width = window.innerWidth);
    let h = (canvas.height = window.innerHeight);
    window.addEventListener('resize', () => {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
    });
    type Shape = { x: number; y: number; life: number; size: number; rotation: number; rotSpeed: number; type: string };
    const shapes: Shape[] = [];
    const TYPES = ['diamond', 'triangle', 'square'];
    window.addEventListener('mousemove', (e) => {
      if (Math.random() > 0.55) return;
      shapes.push({
        x: e.clientX, y: e.clientY, life: 1,
        size: 4 + Math.random() * 7,
        rotation: Math.random() * Math.PI * 2,
        rotSpeed: (Math.random() - 0.5) * 0.1,
        type: TYPES[Math.floor(Math.random() * TYPES.length)],
      });
      if (shapes.length > 40) shapes.shift();
    });
    const draw = () => {
      ctx.clearRect(0, 0, w, h);
      shapes.forEach((s) => {
        s.life -= 0.022;
        s.rotation += s.rotSpeed;
        if (s.life <= 0) return;
        const sz = s.size;
        ctx.save();
        ctx.translate(s.x, s.y);
        ctx.rotate(s.rotation);
        ctx.globalAlpha = s.life * 0.75;
        ctx.strokeStyle = `rgba(255,255,255,${s.life})`;
        ctx.fillStyle = `rgba(255,255,255,${s.life * 0.12})`;
        ctx.lineWidth = 0.8;
        ctx.beginPath();
        if (s.type === 'diamond') {
          ctx.moveTo(0, -sz); ctx.lineTo(sz, 0); ctx.lineTo(0, sz); ctx.lineTo(-sz, 0); ctx.closePath();
        } else if (s.type === 'triangle') {
          ctx.moveTo(0, -sz); ctx.lineTo(sz * 0.866, sz * 0.5); ctx.lineTo(-sz * 0.866, sz * 0.5); ctx.closePath();
        } else {
          ctx.rect(-sz * 0.6, -sz * 0.6, sz * 1.2, sz * 1.2);
        }
        ctx.fill(); ctx.stroke();
        ctx.restore();
      });
      requestAnimationFrame(draw);
    };
    draw();
  }

  // ===== Local clock (JST) =====
  const clockEl = document.getElementById('local-clock');
  if (clockEl) {
    const updateClock = () => {
      const now = new Date();
      const jst = new Date(now.toLocaleString('en-US', { timeZone: 'Asia/Tokyo' }));
      const hh = String(jst.getHours()).padStart(2, '0');
      const mm = String(jst.getMinutes()).padStart(2, '0');
      clockEl.textContent = `${hh}:${mm}`;
    };
    updateClock();
    setInterval(updateClock, 15000);
  }

  // ===== Contact form (Netlify AJAX submit) =====
  const form = document.querySelector('.mn-form') as HTMLFormElement | null;
  const status = document.getElementById('cf-status');
  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.classList.remove('error');
      status.textContent = '送信中…';
      try {
        const data = new FormData(form);
        await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(data as any).toString(),
        });
        form.reset();
        status.textContent = '送信しました。ありがとうございます — 通常 24 時間以内に返信します。';
      } catch (err) {
        status.classList.add('error');
        status.textContent = '送信に失敗しました。時間をおいて再度お試しください。';
      }
    });
  }

  // sent=1 (fallback for non-JS POST redirect)
  if (new URLSearchParams(location.search).get('sent') === '1' && status) {
    status.textContent = '送信しました。ありがとうございます。';
  }
</script>
