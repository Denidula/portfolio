---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Background from '../components/Background.astro';
import Footer from '../components/Footer.astro';
import WorkCard from '../components/WorkCard.astro';
import { works } from '../data/works';
---

<Layout
  title="Works | Dulal Denislam"
  description="Dulal Denislam（デニスラム ドゥラル）の制作実績・事例紹介ページ。公開できる事例を順次追加していきます。"
>
  <div class="mn-root">
    <Background />
    <Header active="works" />

    <div class="mn-wrap">
      <main class="mn-main">
        <div class="mn-eyebrow"><span>WORKS</span></div>
        <h1 class="mn-name md">Works.</h1>
        <p class="mn-tagline static">
          公開できる事例を<em>順次追加</em>しています。
        </p>

        <section class="mn-section tight fade-up">
          <div class="mn-section-h">
            <span class="mn-section-num">01</span>
            <h2 class="mn-section-title">公開作品 / Selected works</h2>
            <span class="mn-section-meta">{works.length} item{works.length > 1 ? 's' : ''}</span>
          </div>
          <div class="mn-works-grid">
            {works.map(w => <WorkCard work={w} />)}
          </div>
        </section>

        <section class="mn-section fade-up">
          <div class="mn-section-h">
            <span class="mn-section-num">02</span>
            <h2 class="mn-section-title">非公開案件 / NDA</h2>
            <span class="mn-section-meta">in progress</span>
          </div>
          <div class="mn-tl">
            <div class="mn-tl-row">
              <div class="mn-tl-year">NDA</div>
              <div class="mn-tl-text">現在の案件は公開できないものが中心です。<span class="muted">出せるものが揃い次第、ここに掲載します。</span></div>
              <div class="mn-tl-tag">soon</div>
            </div>
          </div>
        </section>
      </main>
    </div>

    <Footer />
  </div>
</Layout>

<style is:global>
  .mn-section.tight { margin-top: 72px; }
  .mn-works-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  @media (max-width: 760px) {
    .mn-works-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }
</style>

<script>
  import '../scripts/effects';
</script>
