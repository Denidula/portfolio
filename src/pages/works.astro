---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Works | Dulal Denislam">
  <canvas id="glow-canvas" aria-hidden="true"></canvas>

  <nav>
    <a href="/" class="logo">DD</a>
    <div class="links">
      <a href="/#about">About</a>
      <a href="/works" class="active">Works</a>
      <a href="/#contact">Contact</a>
    </div>
  </nav>

  <main>
    <div class="hero">
      <span class="badge fade-in">Portfolio</span>
      <h1 class="fade-in">Works</h1>
      <p class="coming-soon fade-in">Coming soon — 近日公開予定</p>
    </div>
  </main>

  <footer>
    <p>© 2026 Dulal Denislam</p>
  </footer>
</Layout>

<style>
  #glow-canvas {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  nav, main, footer {
    position: relative;
    z-index: 1;
  }

  nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 36px 0 28px;
    border-bottom: 1px solid var(--border);
  }

  .logo {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--accent);
    letter-spacing: 0.12em;
    text-decoration: none;
  }

  .links {
    display: flex;
    gap: 32px;
  }

  .links a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.88rem;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }

  .links a:hover {
    color: var(--text);
  }

  .links a.active {
    color: var(--text);
  }

  main {
    min-height: 70vh;
    display: flex;
    align-items: center;
  }

  .hero {
    padding: 80px 0;
  }

  .badge {
    display: inline-block;
    background: rgba(110, 231, 183, 0.08);
    color: var(--accent);
    border: 1px solid rgba(110, 231, 183, 0.25);
    padding: 5px 14px;
    border-radius: 20px;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    margin-bottom: 24px;
  }

  h1 {
    font-size: clamp(2.8rem, 9vw, 4.5rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 20px;
  }

  .coming-soon {
    font-size: 1.05rem;
    color: var(--text-muted);
  }

  footer {
    text-align: center;
    padding: 48px 0 40px;
    color: var(--text-muted);
    font-size: 0.82rem;
    border-top: 1px solid var(--border);
  }
</style>

<script>
  const canvas = document.getElementById('glow-canvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  const orbs = [
    { x: 0.15, y: 0.2,  baseR: 28, speed: 0.022, phase: 0,   color: '110,231,183' },
    { x: 0.8,  y: 0.6,  baseR: 22, speed: 0.018, phase: 2.1, color: '139,92,246'  },
    { x: 0.5,  y: 0.85, baseR: 18, speed: 0.026, phase: 4.2, color: '56,189,248'  },
    { x: 0.7,  y: 0.15, baseR: 20, speed: 0.02,  phase: 1.5, color: '110,231,183' },
    { x: 0.3,  y: 0.65, baseR: 16, speed: 0.03,  phase: 3.3, color: '139,92,246'  },
  ].map(o => ({
    ...o,
    cx: o.x * window.innerWidth,
    cy: o.y * window.innerHeight,
  }));

  let t = 0;
  function draw() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    t += 0.016;

    orbs.forEach(orb => {
      const pulse = Math.sin(t * orb.speed * 60 + orb.phase);
      const r = orb.baseR + pulse * 8;

      orb.cx += Math.sin(t * orb.speed * 35 + orb.phase) * 1.0;
      orb.cy += Math.cos(t * orb.speed * 28 + orb.phase) * 0.8;

      const grad = ctx.createRadialGradient(orb.cx, orb.cy, 0, orb.cx, orb.cy, r * 5);
      grad.addColorStop(0,   `rgba(${orb.color},0.3)`);
      grad.addColorStop(0.4, `rgba(${orb.color},0.1)`);
      grad.addColorStop(1,   `rgba(${orb.color},0)`);

      ctx.beginPath();
      ctx.arc(orb.cx, orb.cy, r * 5, 0, Math.PI * 2);
      ctx.fillStyle = grad;
      ctx.fill();
    });

    requestAnimationFrame(draw);
  }
  draw();
</script>
