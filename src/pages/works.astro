---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Works | Dulal Denislam"
  description="Dulal Denislam（デニスラム ドゥラル）の制作実績・事例紹介ページ。公開できる事例を順次追加していきます。"
>
  <div class="mn-root">
    <canvas class="mn-trail-canvas" aria-hidden="true"></canvas>

    <div class="mn-bg grid-glow">
      <div class="glow-soft"></div>
      <div class="mn-star"></div>
    </div>

    <header class="mn-topbar">
      <a class="mn-brand-btn" href="/" style="text-decoration:none;">
        <span class="dot"></span>
        <span class="name">Dulal Denislam</span>
      </a>
      <nav class="mn-nav-top">
        <a href="/#mn-about" data-nav="about">About</a>
        <a href="/works" data-nav="works" class="active">Works</a>
        <a href="/#mn-contact" data-nav="contact">Contact</a>
      </nav>
    </header>

    <div class="mn-wrap" style="grid-template-columns: 1fr;">
      <main class="mn-main">
        <div class="mn-eyebrow"><span>WORKS</span></div>
        <h1 class="mn-name" style="font-size:56px;">Coming soon.</h1>
        <p class="mn-tagline" style="opacity:1; transform:none; animation:none;">
          公開できる事例を、これから<em>順次追加</em>していきます。
        </p>

        <section class="mn-section" style="margin-top:72px;">
          <div class="mn-section-h">
            <span class="mn-section-num">—</span>
            <span class="mn-section-title">準備中</span>
            <span class="mn-section-meta">in progress</span>
          </div>
          <div class="mn-tl">
            <div class="mn-tl-row">
              <div class="mn-tl-year">NDA</div>
              <div class="mn-tl-text">現在の案件は公開できないものが中心です。<span class="muted">出せるものが揃い次第、ここに掲載します。</span></div>
              <div class="mn-tl-tag">soon</div>
            </div>
          </div>
        </section>
      </main>
    </div>

    <Footer />
  </div>
</Layout>

<script>
  import '../scripts/effects';
</script>
