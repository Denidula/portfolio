---
// お問い合わせフォーム（Netlify Forms 連携）
// 送信処理のJSもこのコンポーネントが持つ
---
<section class="mn-section fade-up" id="mn-contact" data-nav="contact">
  <div class="mn-section-h">
    <span class="mn-section-num">03</span>
    <h2 class="mn-section-title">連絡 / Contact</h2>
    <span class="mn-section-meta">≤ 24h reply</span>
  </div>

  <div class="mn-contact">
    <form
      class="mn-form"
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action="/?sent=1"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p hidden>
        <label>Don't fill this out: <input name="bot-field" /></label>
      </p>

      <div class="mn-row">
        <div class="mn-field">
          <label class="mn-label" for="cf-name">NAME / お名前</label>
          <input class="mn-input" id="cf-name" name="name" placeholder="山田 太郎" required />
        </div>
        <div class="mn-field">
          <label class="mn-label" for="cf-email">EMAIL</label>
          <input class="mn-input" id="cf-email" type="email" name="email" placeholder="your@email.com" required />
        </div>
      </div>
      <div class="mn-field">
        <label class="mn-label" for="cf-message">MESSAGE / メッセージ</label>
        <textarea class="mn-input ta" id="cf-message" name="message" placeholder="お問い合わせ内容をご記入ください" required></textarea>
      </div>
      <div class="mn-submit-row">
        <span class="mn-submit-note">— 通常 24 時間以内に返信します</span>
        <button type="submit" class="mn-submit">Send →</button>
      </div>
      <div class="mn-form-status" id="cf-status" role="status" aria-live="polite"></div>
    </form>
  </div>
</section>

<!-- フォーム専用CSS（Layout から移動） -->
<style is:global>
  .mn-contact { margin-top: 8px; }
  .mn-row { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; }
  .mn-form { display: flex; flex-direction: column; gap: 32px; }
  .mn-field { display: flex; flex-direction: column; gap: 8px; }
  .mn-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
    letter-spacing: 0.06em;
  }
  .mn-input {
    background: rgba(255, 255, 255, 0.04);
    border: none;
    border-bottom: 1px solid var(--border-2);
    padding: 12px 14px 14px;
    color: var(--text);
    font-family: inherit;
    font-size: 18px;
    outline: none;
    transition: background 0.15s, border-color 0.15s;
    width: 100%;
    box-sizing: border-box;
  }
  .mn-input:focus { background: rgba(255, 255, 255, 0.07); border-bottom-color: var(--text); }
  .mn-input::placeholder { color: var(--border-3); }
  .mn-input.ta { min-height: 140px; resize: vertical; line-height: 1.5; }
  .mn-submit-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 8px;
    padding-top: 20px;
    border-top: 1px solid var(--hairline);
  }
  .mn-submit {
    background: var(--text);
    color: var(--bg);
    border: none;
    padding: 14px 32px;
    font-family: inherit;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    letter-spacing: 0.01em;
    border-radius: 0;
    transition: background 0.15s;
  }
  .mn-submit:hover { background: #ffffff; }
  .mn-submit-note {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
    letter-spacing: 0.04em;
  }
  .mn-form-status {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    margin-top: 16px;
    min-height: 1em;
  }
  .mn-form-status.error { color: #e0a0a0; }

  @media (max-width: 760px) {
    .mn-row { grid-template-columns: 1fr; gap: 22px; }
    .mn-form { gap: 22px; }
    .mn-input { font-size: 16px; }
    .mn-input.ta { min-height: 110px; }
    .mn-submit-row { flex-direction: column; align-items: stretch; gap: 14px; padding-top: 14px; }
    .mn-submit { padding: 14px; text-align: center; font-size: 14px; }
    .mn-submit-note { text-align: center; }
  }
</style>

<script>
  // ===== Contact form (Netlify AJAX submit) =====
  const form = document.querySelector('.mn-form') as HTMLFormElement | null;
  const status = document.getElementById('cf-status');
  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      status.classList.remove('error');
      status.textContent = '送信中…';
      try {
        const data = new FormData(form);
        const res = await fetch('/', {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
          body: new URLSearchParams(data as any).toString(),
        });
        if (!res.ok) throw new Error(`HTTP ${res.status}`);
        form.reset();
        status.textContent = '送信しました。ありがとうございます — 通常 24 時間以内に返信します。';
      } catch (err) {
        status.classList.add('error');
        status.textContent = '送信に失敗しました。時間をおいて再度お試しください。';
      }
    });
  }

  // sent=1 (fallback for non-JS POST redirect)
  if (new URLSearchParams(location.search).get('sent') === '1' && status) {
    status.textContent = '送信しました。ありがとうございます。';
  }
</script>
