---
// お問い合わせフォーム（Netlify Forms 連携）
---
<section class="mn-section fade-up" id="mn-contact" data-nav="contact">
  <div class="mn-section-h">
    <span class="mn-section-num">03</span>
    <span class="mn-section-title">連絡 / Contact</span>
    <span class="mn-section-meta">≤ 24h reply</span>
  </div>

  <div class="mn-contact">
    <form
      class="mn-form"
      name="contact"
      method="POST"
      data-netlify="true"
      netlify-honeypot="bot-field"
      action="/?sent=1"
    >
      <input type="hidden" name="form-name" value="contact" />
      <p hidden>
        <label>Don't fill this out: <input name="bot-field" /></label>
      </p>

      <div class="mn-row">
        <div class="mn-field">
          <label class="mn-label" for="cf-name">NAME / お名前</label>
          <input class="mn-input" id="cf-name" name="name" placeholder="山田 太郎" required />
        </div>
        <div class="mn-field">
          <label class="mn-label" for="cf-email">EMAIL</label>
          <input class="mn-input" id="cf-email" type="email" name="email" placeholder="your@email.com" required />
        </div>
      </div>
      <div class="mn-field">
        <label class="mn-label" for="cf-message">MESSAGE / メッセージ</label>
        <textarea class="mn-input ta" id="cf-message" name="message" placeholder="お問い合わせ内容をご記入ください" required></textarea>
      </div>
      <div class="mn-submit-row">
        <span class="mn-submit-note">— 通常 24 時間以内に返信します</span>
        <button type="submit" class="mn-submit">Send →</button>
      </div>
      <div class="mn-form-status" id="cf-status" role="status" aria-live="polite"></div>
    </form>
  </div>
</section>
