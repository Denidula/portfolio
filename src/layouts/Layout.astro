---
interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Dulal Denislam（デニスラム ドゥラル）のポートフォリオサイト。プロジェクトリーダーとしてIT企業に勤務し、AI導入推進も担当。" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="index, follow" />
    <meta name="google-site-verification" content="6UHogfCOmU3JJ5B7wPkKyD-ByqVYxU2vNJXRfYvNefw" />
    <link rel="canonical" href="https://dulaldenislam.netlify.app/" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    --bg: #0a0a0a;
    --bg-card: #141414;
    --text: #e8e8e8;
    --text-muted: #777;
    --accent: #6ee7b7;
    --border: #222;
  }

  html {
    font-family: 'Helvetica Neue', Arial, 'Hiragino Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    scroll-behavior: smooth;
  }

  body {
    max-width: 780px;
    margin: 0 auto;
    padding: 0 28px;
  }
</style>
