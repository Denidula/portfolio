---
interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
  ogImage?: string;
}
const {
  title,
  description = 'Dulal Denislam（デニスラム ドゥラル）のポートフォリオサイト。インフラチームのプロジェクトリーダーを務めながら、社内のAI導入推進に力を入れています。',
  noindex = false,
  ogImage: ogImageProp = '/og.png',
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(ogImageProp, Astro.site).href;
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Dulal Denislam',
  alternateName: 'デニスラム ドゥラル',
  jobTitle: 'Project Leader / AI Specialist',
  url: Astro.site?.href,
  sameAs: ['https://github.com/Denidula'],
};
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <meta name="google-site-verification" content="6UHogfCOmU3JJ5B7wPkKyD-ByqVYxU2vNJXRfYvNefw" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Dulal Denislam" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>

<!--
  グローバルスタイル:
  ここには「デザイントークン + ベース + 複数ページで共有するレイアウト」だけを置く。
  各コンポーネント固有のCSSはそれぞれの .astro ファイルに移動済み:
    - Header.astro   … topbar / nav / drawer
    - Background.astro … 背景グリッド / 星 / トレイルcanvas
    - About.astro    … hobbies
    - Contact.astro  … フォーム
    - Footer.astro   … フッター
  (.mn-tl-* タイムラインは index と works の両方で使うためここに残す)
-->
<style is:global>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  :root {
    /* surfaces */
    --bg: #0a0a0a;
    --surface: rgba(18, 18, 16, 0.92);
    /* text scale (明 → 暗) */
    --accent-bright: #f5f3ef;
    --text: #e8e6e2;
    --text-soft: #c0bdb6;
    --text-dim: #b0aea8;
    --text-muted: #8a8884;
    --text-faint: #7d7d78;
    /* lines (淡 → 濃) */
    --hairline: #1a1a18;
    --border: #2a2a26;
    --border-2: #3a3a36;
    --border-3: #4a4a48;
    /* type */
    --font-sans: 'Geist', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    --font-mono: 'Geist Mono', 'JetBrains Mono', monospace;
  }

  html {
    background: var(--bg);
    color: var(--text);
    scroll-behavior: smooth;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  body {
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  .mn-mono { font-family: var(--font-mono); }

  /* キーボードフォーカス */
  a:focus-visible,
  button:focus-visible {
    outline: 1px solid var(--accent-bright);
    outline-offset: 3px;
  }
  .mn-input:focus-visible {
    outline: none; /* 下ボーダー + 背景変化で表現 */
  }

  /* ============================================================
     ROOT + LAYOUT
     ============================================================ */
  .mn-root {
    width: 100%;
    min-height: 100vh;
    background: var(--bg);
    color: var(--text);
    position: relative;
    isolation: isolate;
  }

  .mn-wrap,
  .mn-meta-rail,
  main.mn-main,
  .mn-topbar,
  .mn-drawer,
  .mn-footer-bottom { position: relative; z-index: 1; }

  /* デフォルトは1カラム。メタレールを持つページだけ .has-rail を付ける */
  .mn-wrap {
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
    padding: 96px 140px 0;
    align-items: start;
  }
  .mn-wrap.has-rail { grid-template-columns: 1fr 240px; }

  /* ============================================================
     MAIN + HERO
     ============================================================ */
  .mn-main { padding-top: 24px; min-width: 0; }
  .mn-eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
    letter-spacing: 0.04em;
    margin-bottom: 28px;
    display: flex;
    gap: 14px;
  }
  .mn-name {
    font-size: 72px;
    font-weight: 400;
    line-height: 1.02;
    letter-spacing: -0.035em;
    margin: 0;
    color: var(--accent-bright);
  }
  .mn-name.md { font-size: 56px; }
  .mn-name-ja {
    font-size: 14px;
    color: var(--text-faint);
    margin-top: 18px;
    letter-spacing: 0.04em;
  }
  .mn-tagline {
    font-size: 22px;
    font-weight: 300;
    color: var(--text-soft);
    line-height: 1.45;
    margin: 40px 0 0;
    max-width: 540px;
    letter-spacing: -0.005em;
  }
  .mn-tagline em { font-style: normal; color: var(--accent-bright); font-weight: 400; }

  .mn-hero-foot {
    margin-top: 56px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    padding-top: 20px;
    border-top: 1px solid var(--hairline);
  }
  .mn-fact-k {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--text-faint);
    letter-spacing: 0.06em;
    margin-bottom: 6px;
  }
  .mn-fact-v { font-size: 13.5px; color: var(--text); }

  /* ============================================================
     SECTIONS（index / works 共有）
     ============================================================ */
  .mn-section {
    margin-top: 96px;
    padding-top: 28px;
    border-top: 1px solid var(--hairline);
    /* 固定ヘッダーの下に見出しが潜らないように */
    scroll-margin-top: 88px;
  }
  .mn-section-h {
    display: grid;
    grid-template-columns: 40px 1fr auto;
    gap: 20px;
    align-items: baseline;
    margin-bottom: 36px;
  }
  .mn-section-num {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-faint);
    letter-spacing: 0.06em;
  }
  /* h2 になったのでフォント継承とマージンをリセット */
  .mn-section-title {
    font-size: 18px;
    font-weight: 500;
    color: var(--accent-bright);
    letter-spacing: -0.005em;
    margin: 0;
  }
  .mn-section-meta {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--text-faint);
    letter-spacing: 0.04em;
  }

  /* Timeline（index の経歴 / works の準備中で共有） */
  .mn-tl { display: flex; flex-direction: column; }
  .mn-tl-row {
    display: grid;
    grid-template-columns: 100px 1fr 120px;
    gap: 28px;
    padding: 18px 0;
    border-top: 1px solid var(--hairline);
    align-items: baseline;
  }
  .mn-tl-row:first-child { border-top: none; padding-top: 4px; }
  .mn-tl-year {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    letter-spacing: 0.02em;
  }
  .mn-tl-row.now .mn-tl-year { color: var(--accent-bright); }
  .mn-tl-text { font-size: 14px; color: var(--text); line-height: 1.6; max-width: 520px; }
  .mn-tl-text .muted { color: var(--text-muted); display: block; margin-top: 2px; font-size: 12.5px; }
  .mn-tl-tag {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--text-faint);
    text-align: right;
    letter-spacing: 0.04em;
  }
  .mn-tl-row.now .mn-tl-tag { color: var(--accent-bright); position: relative; }
  .mn-tl-row.now .mn-tl-tag::before {
    content: '';
    position: absolute;
    left: -16px; top: 6px;
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--text);
    box-shadow: 0 0 0 3px #1f1f1d;
  }

  /* ============================================================
     ANIMATIONS
     ============================================================ */
  /* A: char reveal */
  .char {
    display: inline-block;
    opacity: 0;
    transform: translateY(5px);
    animation: mn-char-in 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }
  @keyframes mn-char-in { to { opacity: 1; transform: translateY(0); } }
  .mn-tagline {
    opacity: 0;
    transform: translateY(10px);
    animation: mn-char-in 1.4s cubic-bezier(0.22, 1, 0.36, 1) 2.2s forwards;
  }
  /* 入場アニメ不要のページ用（works 等） */
  .mn-tagline.static { opacity: 1; transform: none; animation: none; }
  /* C: fade up */
  .fade-up {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 1.4s ease, transform 1.4s ease;
  }
  .fade-up.visible { opacity: 1; transform: translateY(0); }

  @media (prefers-reduced-motion: reduce) {
    .char, .mn-tagline { animation: none !important; opacity: 1 !important; transform: none !important; }
    .fade-up { transition: none !important; opacity: 1 !important; transform: none !important; }
  }

  /* ============================================================
     RESPONSIVE（グローバル分のみ。各コンポーネント分は各ファイルへ）
     ============================================================ */
  @media (max-width: 1100px) {
    .mn-wrap, .mn-wrap.has-rail { grid-template-columns: 1fr; gap: 0; padding: 88px 88px 0; }
    .mn-name { font-size: 58px; letter-spacing: -0.03em; }
    .mn-tagline { font-size: 19px; max-width: 100%; }
    .mn-hero-foot { grid-template-columns: repeat(4, 1fr); gap: 14px; }
  }
  @media (max-width: 760px) {
    .mn-wrap, .mn-wrap.has-rail { padding: 76px 24px 0; }
    .mn-main { padding-top: 0; }
    .mn-eyebrow { flex-wrap: wrap; gap: 6px 12px; margin-bottom: 20px; }
    .mn-name { font-size: 40px; letter-spacing: -0.03em; }
    .mn-name-ja { font-size: 12.5px; margin-top: 14px; }
    .mn-tagline { font-size: 16px; line-height: 1.55; margin: 28px 0 0; }
    .mn-hero-foot { grid-template-columns: 1fr 1fr; gap: 16px 20px; margin-top: 36px; padding-top: 18px; }
    .mn-section { margin-top: 56px; padding-top: 20px; scroll-margin-top: 72px; }
    .mn-section-h {
      grid-template-columns: 28px 1fr;
      grid-template-areas: "num title" "meta meta";
      gap: 10px 14px;
      margin-bottom: 22px;
    }
    .mn-section-num { grid-area: num; }
    .mn-section-title { grid-area: title; font-size: 17px; }
    .mn-section-meta { grid-area: meta; margin-top: 4px; }
    .mn-tl-row {
      grid-template-columns: 88px 1fr;
      grid-template-areas: "year text" "year tag";
      gap: 6px 16px;
      padding: 16px 0;
    }
    .mn-tl-year { grid-area: year; font-size: 11.5px; }
    .mn-tl-text { grid-area: text; font-size: 13.5px; max-width: 100%; }
    .mn-tl-tag { grid-area: tag; text-align: left; font-size: 10px; opacity: 0.7; }
    .mn-tl-row.now .mn-tl-tag::before { left: -10px; top: 6px; width: 5px; height: 5px; }
  }
  @media (max-width: 400px) {
    .mn-wrap, .mn-wrap.has-rail { padding: 76px 16px 0; }
    .mn-name { font-size: 34px; }
    .mn-hero-foot { grid-template-columns: 1fr 1fr; }
  }
</style>
